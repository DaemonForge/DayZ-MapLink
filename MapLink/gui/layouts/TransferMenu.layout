FrameWidgetClass rootFrame {
 size 1 1
 hexactsize 0
 vexactsize 0
 {
  ImageWidgetClass TransferMenuOverlay {
   ignorepointer 1
   color 0 0 0 0.5
   size 1 1
   hexactsize 0
   vexactsize 0
   image0 "set:rover_imageset image:WhitePixel"
   mode blend
   "src alpha" 1
   stretch 1
  }
  FrameWidgetClass TransferMenuContainer {
   size 700 440
   halign center_ref
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   scaled 1
   clipchildren 1
   {
    ImageWidgetClass TransferMenuBG {
     ignorepointer 1
     color 0.04 0.04 0.06 0.85
     size 700 440
     hexactsize 1
     vexactsize 1
     scaled 1
     image0 "set:rover_imageset image:WhitePixel"
     mode blend
     "src alpha" 1
     stretch 1
    }
    PanelWidgetClass TransferMenuBorder {
     ignorepointer 1
     color 0.2902 0.4549 0.7529 1
     size 700 440
     hexactsize 1
     vexactsize 1
     scaled 1
     style Outline
    }
    RichTextWidgetClass Heading {
     ignorepointer 1
     position 0 10
     size 700 44
     halign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     text "DEPARTURE POINT"
     font "gui/fonts/metronbook"
     "exact text" 0
     text_proportion 0.65
     "text halign" center
     "text valign" center
    }
    PanelWidgetClass separator_heading {
     ignorepointer 1
     color 0.2902 0.4549 0.7529 0.5
     position 30 58
     size 640 1
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     style rover_sim_colorable
    }
    ScrollWidgetClass ArrivalPoints_Scroll {
     position 10 66
     size 680 306
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     style blank
     "Scrollbar V" 1
     {
      GridSpacerWidgetClass ArrivalPoints_Grid {
       ignorepointer 1
       size 1 1
       hexactsize 0
       vexactsize 0
       Padding 4
       "Size To Content V" 1
       Columns 1
       Rows 99
      }
     }
    }
    PanelWidgetClass separator_bottom {
     ignorepointer 1
     color 0.2902 0.4549 0.7529 0.5
     position 30 380
     size 640 1
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     style rover_sim_colorable
    }
    ButtonWidgetClass Cancel {
     position 0 392
     size 260 42
     halign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     style blank
     "no focus" 1
     {
      ImageWidgetClass Cancel_panel {
       ignorepointer 1
       color 0.04 0.04 0.06 0.8
       size 260 42
       hexactsize 1
       vexactsize 1
       scaled 1
       image0 "set:rover_imageset image:WhitePixel"
       mode blend
       "src alpha" 1
       stretch 1
      }
      PanelWidgetClass Cancel_border {
       ignorepointer 1
       color 0.2902 0.4549 0.7529 1
       size 260 42
       hexactsize 1
       vexactsize 1
       scaled 1
       style Outline
      }
      TextWidgetClass Cancel_label {
       ignorepointer 1
       color 0.2902 0.4549 0.7529 1
       size 1 1
       hexactsize 0
       vexactsize 0
       text "#cancel"
       font "gui/fonts/metronbook"
       "exact text" 0
       text_proportion 0.6
       "text halign" center
       "text valign" center
      }
     }
    }
    FrameWidgetClass TransferingTimeFrame {
     visible 0
     ignorepointer 1
     size 260 160
     halign center_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     clipchildren 1
     priority 99
     {
      PanelWidgetClass TransferTimeBorder {
       ignorepointer 1
       color 1 1 1 0.88
       size 260 160
       hexactsize 1
       vexactsize 1
       scaled 1
       style rover_sim_colorable
      }
      PanelWidgetClass TransferTimeBG {
       ignorepointer 1
       color 0.2902 0.4549 0.7529 1
       position 1 1
       size 258 158
       hexactpos 1
       vexactpos 1
       hexactsize 1
       vexactsize 1
       scaled 1
       style rover_sim_colorable
      }
      TextWidgetClass Transfering_text {
       ignorepointer 1
       position 0 16
       size 260 48
       halign center_ref
       hexactpos 1
       vexactpos 1
       hexactsize 1
       vexactsize 1
       scaled 1
       text "Transferring In"
       font "gui/fonts/Metron"
       "exact text" 0
       text_proportion 0.6
       "text halign" center
       "text valign" center
      }
      TextWidgetClass TranferingCountDown {
       ignorepointer 1
       position 0 18
       size 260 60
       halign center_ref
       valign bottom_ref
       hexactpos 1
       vexactpos 1
       hexactsize 1
       vexactsize 1
       scaled 1
       text "10"
       font "gui/fonts/metronbook28"
       "exact text" 0
       text_proportion 0.7
       "text halign" center
       "text valign" center
      }
     }
    }
   }
  }
 }
}
