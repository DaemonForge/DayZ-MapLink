FrameWidgetClass rootFrame {
 size 1 1
 hexactsize 0
 vexactsize 0
 {
  PanelWidgetClass RespawnMenuOverlay {
   ignorepointer 1
   color 0 0 0 0.85
   size 1 1
   hexactsize 0
   vexactsize 0
   style rover_sim_colorable
  }
  FrameWidgetClass RespawnMenuContainer {
   size 550 480
   halign center_ref
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   scaled 1
   clipchildren 1
   {
    PanelWidgetClass RespawnMenuBG {
     ignorepointer 1
     color 0.08 0.08 0.08 0.98
     size 550 480
     hexactsize 1
     vexactsize 1
     scaled 1
     style rover_sim_colorable
    }
    PanelWidgetClass border_top {
     ignorepointer 1
     color 0.7 0 0 1
     size 550 2
     halign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     style rover_sim_colorable
    }
    PanelWidgetClass border_left {
     ignorepointer 1
     color 0.22 0.22 0.22 1
     size 1 480
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     style rover_sim_colorable
    }
    PanelWidgetClass border_right {
     ignorepointer 1
     color 0.22 0.22 0.22 1
     size 1 480
     halign right_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     style rover_sim_colorable
    }
    PanelWidgetClass border_bottom {
     ignorepointer 1
     color 0.22 0.22 0.22 1
     size 550 1
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     style rover_sim_colorable
    }
    TextWidgetClass Heading {
     ignorepointer 1
     position 0 10
     size 550 40
     halign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     text "SELECT SERVER"
     font "gui/fonts/metronbook"
     "exact text" 0
     text_proportion 0.7
     "text halign" center
     "text valign" center
    }
    PanelWidgetClass separator_heading {
     ignorepointer 1
     color 0.7 0 0 0.7
     position 20 54
     size 510 1
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     style rover_sim_colorable
    }
    ScrollWidgetClass RespawnServers_Scroll {
     position 10 62
     size 530 330
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     style blank
     "Scrollbar V" 1
     {
      GridSpacerWidgetClass RespawnServers_Grid {
       ignorepointer 1
       size 1 1
       hexactsize 0
       vexactsize 0
       Padding 0
       "Size To Content V" 1
       Columns 1
       Rows 99
      }
     }
    }
    PanelWidgetClass separator_bottom {
     ignorepointer 1
     color 0.7 0 0 0.7
     position 20 398
     size 510 1
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     style rover_sim_colorable
    }
    ButtonWidgetClass VanillaRespawn {
     position 0 -10
     size 550 38
     halign center_ref
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scaled 1
     {
      PanelWidgetClass VanillaRespawn_panel {
       ignorepointer 1
       color 0 0 0 0
       size 550 38
       hexactsize 1
       vexactsize 1
       scaled 1
       style rover_sim_colorable
      }
      TextWidgetClass VanillaRespawn_label {
       ignorepointer 1
       size 1 1
       hexactsize 0
       vexactsize 0
       text "RESPAWN HERE"
       font "gui/fonts/metronbook"
       "exact text" 0
       text_proportion 0.6
       "text halign" center
       "text valign" center
      }
     }
    }
   }
  }
 }
}
